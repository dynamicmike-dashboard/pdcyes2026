# -------------------------------------------------
# GitHub / NextAuth (used by the /admin area)
# -------------------------------------------------
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret
NEXTAUTH_SECRET=nextauth_secret_string
NEXTAUTH_URL=https://pdcye.com          # or your Vercel preview URL
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=pdcyes-website

# -------------------------------------------------
# Optional – PAT for the hidden /manage admin
# -------------------------------------------------
GITHUB_PAT=ghp_yourPersonalAccessTokenHere   # repo scope

# -------------------------------------------------
# Hidden‑admin password protection
# -------------------------------------------------
MANAGE_PASSWORD=ChooseAStrongSecret1!
MANAGE_COOKIE_NAME=manage_session                     # optional, default

# -------------------------------------------------
# AI assistant
# -------------------------------------------------
OPENAI_API_KEY=sk‑your‑openai‑key

# -------------------------------------------------
# Site URL (used for SEO tags)
# -------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://pdcye.com